{
	"name": "tentui.com",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"registry:build": "turbo run registry:build --filter=web",
		"registry:validate": "turbo run registry:validate --filter=web",
		"check-types": "turbo run check-types",
		"dev:web": "turbo run dev -F web",
		"dev:server": "turbo run dev -F server",
		"db:generate": "turbo run db:generate -F @tentui.com/db",
		"deploy": "turbo run deploy -F @tentui.com/infra",
		"destroy": "turbo run destroy -F @tentui.com/infra",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@tentui.com/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@cloudflare/workers-types": "catalog:",
		"@tentui.com/config": "workspace:*",
		"@types/node": "^22.13.14",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"turbo": "^2.10.2",
		"typescript": "catalog:"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "pnpm@11.8.0"
}
